{
  "extends": "tsconfig/nextjs.json",
  "compilerOptions": {
    "noUncheckedSideEffectImports": false,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@flows/styled-system/*": ["./pandacss-generated/*"],
      "*": ["./src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
